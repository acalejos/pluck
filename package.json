{
  "name": "pluck",
  "version": "0.1.0",
  "description": "Turn any website into a type-safe, verified API.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^3.23",
    "zod-to-json-schema": "^3.23",
    "cheerio": "^1.0.0",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "typescript": "^5.6",
    "vitest": "^2.1",
    "tsx": "^4.19",
    "@types/node": "^22",
    "@types/turndown": "^5"
  },
  "peerDependencies": {
    "swoosh-router": "*"
  },
  "peerDependenciesMeta": {
    "swoosh-router": {
      "optional": true
    }
  }
}
